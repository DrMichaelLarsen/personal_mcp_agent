# Core app
PPMCP_APP_NAME=personal-productivity-mcp
PPMCP_ENVIRONMENT=dev

# Notion
PPMCP_NOTION_API_KEY=secret_your_notion_integration_key

# Google credential file paths
# Use Linux-style mounted paths on Unraid/Docker
PPMCP_GMAIL__CREDENTIALS_PATH=/config/secrets/google-oauth-client.json
PPMCP_CALENDAR__CREDENTIALS_PATH=/config/secrets/google-oauth-client.json
PPMCP_CALENDAR__CALENDAR_ID=primary

# Gmail processing defaults
PPMCP_GMAIL__LABEL_QUERY=label:Actionable -label:Processed
PPMCP_GMAIL__PROCESSED_LABEL=Processed

# Suggested unread/unprocessed query for inbox-driven email-to-task workflows
# Example alternative: is:unread -label:Processed in:inbox

# Attachment handling
# none | drive_link | notion_file
PPMCP_ATTACHMENTS__MODE=drive_link
PPMCP_ATTACHMENTS__MAX_ATTACHMENTS_PER_EMAIL=10
PPMCP_ATTACHMENTS__MAX_ATTACHMENT_SIZE_MB=20
PPMCP_ATTACHMENTS__INCLUDE_LINKS_IN_NOTES=true
PPMCP_ATTACHMENTS__DRIVE_FOLDER_ID=

# LLM routing/tiering
PPMCP_LLM__ENABLED=false
PPMCP_LLM__PROVIDER=openai_compatible
PPMCP_LLM__API_KEY=
PPMCP_LLM__BASE_URL=https://api.openai.com/v1
PPMCP_LLM__GEMINI_API_KEY=
PPMCP_LLM__GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
PPMCP_LLM__XAI_API_KEY=
PPMCP_LLM__XAI_BASE_URL=https://api.x.ai/v1
PPMCP_LLM__ANTHROPIC_API_KEY=
PPMCP_LLM__ANTHROPIC_BASE_URL=https://api.anthropic.com
PPMCP_LLM__CHEAP_MODEL=gpt-5.4-nano
PPMCP_LLM__STANDARD_MODEL=gpt-5.4-mini
PPMCP_LLM__PREMIUM_MODEL=gpt-5.4
PPMCP_LLM__USE_FOR_EMAIL_ANALYSIS=true
PPMCP_LLM__USE_FOR_AMBIGUOUS_MATCHING=true
PPMCP_LLM__QUALITY_TIER=balanced
PPMCP_LLM__EMAIL_ANALYSIS_TIER=balanced
PPMCP_LLM__AMBIGUOUS_MATCHING_TIER=fast
PPMCP_LLM__COST_LEDGER_PATH=data/ai_costs.jsonl

# Notion database IDs
PPMCP_TASKS_DB__DATABASE_ID=your_tasks_database_id
PPMCP_PROJECTS_DB__DATABASE_ID=your_projects_database_id
PPMCP_NOTES_DB__DATABASE_ID=your_notes_database_id
PPMCP_AREAS_DB__DATABASE_ID=your_areas_database_id

# Optional schema mapping overrides
PPMCP_TASKS_DB__TITLE_PROPERTY=Name
PPMCP_TASKS_DB__STATUS_PROPERTY=Status
PPMCP_TASKS_DB__IMPORTANCE_PROPERTY=Importance
PPMCP_TASKS_DB__SCHEDULED_PROPERTY=Scheduled
PPMCP_TASKS_DB__DEADLINE_PROPERTY=Deadline
PPMCP_TASKS_DB__ESTIMATE_PROPERTY=Time Required
PPMCP_TASKS_DB__RELATION_PROPERTY=Project
PPMCP_TASKS_DB__CONTEXTS_PROPERTY=Contexts
PPMCP_TASKS_DB__ASSIGNED_PROPERTY=Assigned
PPMCP_TASKS_DB__PHONE_PROPERTY=Phone
PPMCP_TASKS_DB__BUDGET_PROPERTY=Budget
PPMCP_TASKS_DB__GOAL_PROPERTY=Goal
PPMCP_TASKS_DB__PARENT_PROPERTY=parent
PPMCP_TASKS_DB__DEPENDENCY_OF_PROPERTY=dependency_of
PPMCP_TASKS_DB__DEPENDS_ON_PROPERTY=depends_on
PPMCP_TASKS_DB__SCORE_PROPERTY=Score
PPMCP_TASKS_DB__TAGS_PROPERTY=Tags
PPMCP_TASKS_DB__URL_PROPERTY=URL
PPMCP_TASKS_DB__NOTES_PROPERTY=Description
PPMCP_TASKS_DB__SOURCE_ID_PROPERTY=Source ID
PPMCP_TASKS_DB__AI_COST_PROPERTY=ai_cost

PPMCP_PROJECTS_DB__TITLE_PROPERTY=Name
PPMCP_PROJECTS_DB__STATUS_PROPERTY=Status
PPMCP_PROJECTS_DB__PRIORITY_PROPERTY=Priority
PPMCP_PROJECTS_DB__AREA_PROPERTY=Area
PPMCP_PROJECTS_DB__PARENT_PROJECT_PROPERTY=Parent Project
PPMCP_PROJECTS_DB__TARGET_DEADLINE_PROPERTY=Target Deadline
PPMCP_PROJECTS_DB__IMPORTANCE_PROPERTY=Importance
PPMCP_PROJECTS_DB__PRIORITY_CHECKBOX_PROPERTY=Priority
PPMCP_PROJECTS_DB__BUDGET_PROPERTY=Budget
PPMCP_PROJECTS_DB__SCORE_PROPERTY=Score
PPMCP_PROJECTS_DB__NOTES_PROPERTY=Notes
PPMCP_PROJECTS_DB__TAGS_PROPERTY=Tags

PPMCP_AREAS_DB__TITLE_PROPERTY=Name
PPMCP_AREAS_DB__STATUS_PROPERTY=Status
PPMCP_AREAS_DB__PARENT_PROPERTY=Parent Area

PPMCP_NOTES_DB__TITLE_PROPERTY=Name
PPMCP_NOTES_DB__RELATION_PROPERTY=Project
PPMCP_NOTES_DB__NOTES_PROPERTY=Notes
PPMCP_NOTES_DB__URL_PROPERTY=Source URL
PPMCP_NOTES_DB__SOURCE_ID_PROPERTY=Source ID
PPMCP_NOTES_DB__TAGS_PROPERTY=Tags

# Defaults and thresholds
PPMCP_WORKDAY__START_HOUR=9
PPMCP_WORKDAY__END_HOUR=17
PPMCP_WORKDAY__LUNCH_MINUTES=30
PPMCP_WORKDAY__BUFFER_MINUTES=15
PPMCP_CONFIDENCE__AUTO_CREATE=0.85
PPMCP_CONFIDENCE__REVIEW_REQUIRED=0.65
